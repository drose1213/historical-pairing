{
  "name": "historical-pairing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:client\"",
    "dev:api": "uvicorn app.main:app --reload --host 0.0.0.0 --port 8787 --app-dir server",
    "dev:client": "vite --host 0.0.0.0",
    "build": "vue-tsc -p client/tsconfig.json --noEmit && vite build --config vite.config.ts",
    "typecheck": "vue-tsc -p client/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "lucide-vue-next": "^0.468.0",
    "pinia": "^2.2.0",
    "vue": "^3.5.13",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vue-tsc": "^2.2.0"
  }
}
