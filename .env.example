PORT=8787
CLIENT_ORIGIN=http://localhost:5173

# MySQL. docker-compose.yml uses the same defaults.
# NOTE: Change MYSQL_PASSWORD before deploying to production.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=history_user
MYSQL_PASSWORD=history_pass
MYSQL_DATABASE=historical_pairing

# Optional. If omitted, the server uses a deterministic built-in generator.
# For MiniMax: set OPENAI_API_KEY to your token and OPENAI_BASE_URL to https://api.minimax.chat/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# SMTP email config (optional, for sending registration verification codes)
# Supports QQ Mail (smtp.qq.com:465), 163 Mail (smtp.163.com:465), Gmail (smtp.gmail.com:465), etc.
# SMTP_HOST=
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASSWORD=       # QQ Mail: use authorization code; Gmail: use app password
# SMTP_FROM=           # sender address, defaults to SMTP_USER
# SMTP_TLS=true
