# =============================================================================
# 历史配对 - 环境配置示例
# =============================================================================
# 复制此文件为 .env 并修改相应配置
# 开发环境使用 .env，生产环境使用 .env.production

# =============================================================================
# 服务配置
# =============================================================================

# 后端服务端口 (默认: 8787)
PORT=8787

# 前端访问地址 (用于 CORS 配置)
CLIENT_ORIGIN=http://localhost:5173

# CORS 允许的源 (逗号分隔，留空则使用 CLIENT_ORIGIN)
# 示例: CORS_ORIGINS=https://example.com,https://www.example.com
# CORS_ORIGINS=

# =============================================================================
# 数据库配置 (MySQL)
# =============================================================================
# docker-compose.yml 使用相同的默认值

# MySQL 主机地址
MYSQL_HOST=127.0.0.1

# MySQL 端口
MYSQL_PORT=3306

# MySQL 用户名
MYSQL_USER=history_user

# MySQL 密码 (⚠️ 生产环境必须修改)
MYSQL_PASSWORD=history_pass

# MySQL 数据库名
MYSQL_DATABASE=historical_pairing

# =============================================================================
# JWT 认证配置
# =============================================================================

# JWT 签名密钥 (⚠️ 生产环境必须使用强随机密钥，不能使用默认值)
# 建议: 使用 32+ 字符的随机字符串
JWT_SECRET_KEY=your-secret-key-change-in-production

# 跳过 JWT 密钥检查 (仅用于开发，生产环境勿用)
JWI_SKIP_SECRET_CHECK=1

# JWT 过期时间 (分钟，默认 7 天 = 10080)
# JWT_EXPIRE_MINUTES=10080

# =============================================================================
# AI 题库生成配置 (可选)
# =============================================================================
# 不配置时使用内置兜底题库

# AI 服务 API Key
# MiniMax: https://api.minimax.chat/v1
# OpenAI: https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com/v1
OPENAI_API_KEY=

# AI 服务地址 (留空使用 OpenAI 默认)
OPENAI_BASE_URL=

# AI 模型名称 (默认: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# =============================================================================
# 邮件服务配置 (可选，用于发送注册验证码)
# =============================================================================
# 支持 QQ 邮箱 (smtp.qq.com:465)、163 邮箱、Gmail 等

# SMTP 服务器地址
SMTP_HOST=

# SMTP 端口 (SSL: 465, TLS: 587)
SMTP_PORT=465

# SMTP 用户名 (通常是完整邮箱地址)
SMTP_USER=

# SMTP 密码/授权码
# QQ 邮箱: 使用授权码而非密码
# Gmail: 使用应用专用密码
SMTP_PASSWORD=

# 发件人地址 (留空则使用 SMTP_USER)
SMTP_FROM=

# 是否使用 TLS (QQ/Google 建议 true)
SMTP_TLS=true

# =============================================================================
# 日志配置 (可选)
# =============================================================================

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 日志文件路径 (留空则只输出到控制台)
# LOG_FILE=./logs/app.log

# =============================================================================
# 生产环境额外配置
# =============================================================================

# HTTP 端口 (Nginx)
# HTTP_PORT=80

# HTTPS 端口 (Nginx)
# HTTPS_PORT=443
